# Rex Finance OS environment

# Production Turso/libSQL cloud database.
# Create these in Turso and add them to Vercel Project Settings → Environment Variables.
TURSO_DATABASE_URL=libsql://your-database-org.turso.io
TURSO_AUTH_TOKEN=your_turso_database_token

# Optional local development fallback path. If omitted, the app uses ./data/rex-finance-os.sqlite
REX_FINANCE_DB_PATH=./data/rex-finance-os.sqlite
